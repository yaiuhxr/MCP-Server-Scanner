# pyenv
#   For a library or app, you might want to share your .python-version if you're using pyenv, but commonly ignore it
#.python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, if you're executing coding examples, you might want to ignore it.
#Pipfile.lock

# poetry
#   Poetry uses pyproject.toml and poetry.lock.
#poetry.lock

# pdm
#   PDM stores project-wide configurations in .pdm.toml
.pdm.toml
.pdm-plugins/
__pdm-build/

# PEP 582; used by e.g. github.com/pdm-project/pdm
__pypackages__/

